---
import { Icon } from 'astro-icon/components';
const currentYear = new Date().getFullYear();
---
<footer class="bg-white/50 dark:bg-slate-900/50 border-t border-gray-200/50 dark:border-slate-700/50 p-4 mt-auto">
  <div class="container mx-auto text-center text-gray-600 dark:text-slate-400">
    <div class="flex justify-center space-x-6 mb-4">
      <a href="https://github.com/faisaldurbaa" target="_blank" rel="noopener noreferrer" aria-label="GitHub Profile" class="cursor-pointer">
        <Icon name="mdi:github" class="w-6 h-6 text-gray-600 dark:text-slate-400 hover:text-accent dark:hover:text-slate-200 transition-colors" />
      </a>
      <a href="https://www.linkedin.com/in/faisaldurbaa/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn Profile" class="cursor-pointer">
        <Icon name="mdi:linkedin" class="w-6 h-6 text-gray-600 dark:text-slate-400 hover:text-accent dark:hover:text-slate-200 transition-colors" />
      </a>
    </div>
    <p>© {currentYear} Faisal Durbaa. All rights reserved.</p>
  </div>
</footer>
